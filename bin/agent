#!/usr/bin/env bash
set -euo pipefail

KNOWN_TOOLS="codex claude opencode codemachine omp"
NIX_FEATURES="${AGENT_NIX_EXPERIMENTAL_FEATURES:-nix-command flakes}"
PERF_LOG="${AGENT_PERF_LOG:-1}"

now_ms() {
  local ts
  ts="$(date +%s%3N 2>/dev/null || true)"
  case "$ts" in
    *N*|"")
      echo "$(( $(date +%s) * 1000 ))"
      ;;
    *)
      echo "$ts"
      ;;
  esac
}

format_duration_ms() {
  local ms="$1"
  if [ "$ms" -ge 1000 ]; then
    printf '%d.%03ds' $((ms / 1000)) $((ms % 1000))
  else
    printf '%dms' "$ms"
  fi
}

perf_log() {
  if [ "$PERF_LOG" = "0" ]; then
    return
  fi
  echo "[perf] $*" >&2
}

contains_word() {
  local needle="$1"
  shift
  local item
  for item in "$@"; do
    if [ "$item" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

split_csv_or_lines() {
  local value="$1"
  printf '%s\n' "$value" | tr ',' '\n' | sed '/^[[:space:]]*$/d'
}

hash_short() {
  local value="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$value" | sha256sum | awk '{print substr($1,1,16)}'
  elif command -v sha1sum >/dev/null 2>&1; then
    printf '%s' "$value" | sha1sum | awk '{print substr($1,1,16)}'
  elif command -v shasum >/dev/null 2>&1; then
    printf '%s' "$value" | shasum -a 256 | awk '{print substr($1,1,16)}'
  else
    printf '%s' "$value" | tr -cd 'a-zA-Z0-9' | head -c 16
  fi
}

nix_cmd() {
  env -u NIX_CONFIG nix --extra-experimental-features "$NIX_FEATURES" "$@"
}

AGENT_BIN_DIR="$(CDPATH= cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$AGENT_BIN_DIR/lib/cli.sh"
. "$AGENT_BIN_DIR/lib/project_contract.sh"
. "$AGENT_BIN_DIR/lib/rootfs.sh"
. "$AGENT_BIN_DIR/lib/artifact_prep.sh"
. "$AGENT_BIN_DIR/lib/container_api.sh"
. "$AGENT_BIN_DIR/lib/nix_tool_helper.sh"
. "$AGENT_BIN_DIR/lib/container_runtime.sh"
. "$AGENT_BIN_DIR/lib/dev_env.sh"
. "$AGENT_BIN_DIR/lib/environment.sh"
. "$AGENT_BIN_DIR/lib/doctor.sh"

TOOL=""
REMAINING_ARGS=()
AGENT_COMMAND="run"
if [ "$(basename "$0")" = "agent" ] && [ "${1:-}" = "doctor" ]; then
  AGENT_COMMAND="doctor"
  shift
  REMAINING_ARGS=("$@")
else
  resolve_tool "$@"
fi
RUN_START_MS="$(now_ms)"

if [ -z "$TOOL" ] && [ "${1:-}" = "--version" ]; then
  print_version_and_exit
fi

if [ "$AGENT_COMMAND" = "doctor" ]; then
  [ "${#REMAINING_ARGS[@]}" -eq 0 ] || {
    echo "usage: agent doctor" >&2
    exit 1
  }
  print_doctor_and_exit
fi

validate_tool_access

TMP_DIR=""
HELPER_STATE_DIR=""
cleanup() {
  if [ -n "$TMP_DIR" ] && [ -d "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
  fi
  if [ -n "$HELPER_STATE_DIR" ] && [ -d "$HELPER_STATE_DIR" ]; then
    rm -rf "$HELPER_STATE_DIR"
  fi
}
trap cleanup EXIT

bootstrap_environment
prepare_runtime_artifacts
prepare_container_api
prepare_nix_tool_helper

build_container_args

if [ "${AGENT_DEBUG:-0}" = "1" ]; then
  printf '[agent] running: %s run %q\n' "$RUNTIME" "${ARGS[*]}" >&2
fi

if [ "$MODE" = "podman-rootfs" ]; then
  perf_log "podman rootfs run mode: $ROOTFS_RUN_MODE"
  "$RUNTIME" run "${ARGS[@]}"
  status=$?
  if [ "$status" -ne 0 ]; then
    echo "[agent] podman --rootfs run failed." >&2
    exit "$status"
  fi
  exit 0
fi

exec "$RUNTIME" run "${ARGS[@]}"
